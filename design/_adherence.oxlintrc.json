{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/recruiting/**",
              "ui_kits/analyzer/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|IBM Plex Sans|IBM Plex Serif))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, IBM Plex Sans, IBM Plex Serif."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|title|children|style|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: tone, icon, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|validate|neutral)$/]",
        "message": "<Banner> tone must be one of 'info' | 'validate' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|loading|leadingIcon|trailingIcon|type|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, loading, leadingIcon, trailingIcon, type, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|secondary|subtle|ghost|danger-quiet)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'secondary' | 'subtle' | 'ghost' | 'danger-quiet'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|padding|interactive|as|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: tone, padding, interactive, as, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|sunken|confirmed|validate|gap|uncertain)$/]",
        "message": "<Card> tone must be one of 'default' | 'sunken' | 'confirmed' | 'validate' | 'gap' | 'uncertain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|htmlFor|hint|required|optional|children|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, htmlFor, hint, required, optional, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|invalid|leading|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: size, invalid, leading."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuadrantCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:quadrant|title|source|rationale|interviewFocus|style|key|ref|className|style|children)$/]",
        "message": "<QuadrantCard> doesn't accept that prop. Declared props: quadrant, title, source, rationale, interviewFocus, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuadrantCard'] > JSXAttribute[name.name='quadrant'] > Literal[value!=/^(?:strong_with_evidence|strong_needs_validation|weak_with_evidence|weak_needs_validation)$/]",
        "message": "<QuadrantCard> quadrant must be one of 'strong_with_evidence' | 'strong_needs_validation' | 'weak_with_evidence' | 'weak_needs_validation'."
      },
      {
        "selector": "JSXOpeningElement[name.name='QualBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|style|key|ref|className|style|children)$/]",
        "message": "<QualBadge> doesn't accept that prop. Declared props: label, value, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QualBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:confirmed|validate|gap|uncertain|info|neutral)$/]",
        "message": "<QualBadge> tone must be one of 'confirmed' | 'validate' | 'gap' | 'uncertain' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SourceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|required|filled|meta|action|children|style|key|ref|className|style|children)$/]",
        "message": "<SourceCard> doesn't accept that prop. Declared props: icon, title, description, required, filled, meta, action, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|title|detail|duration|last|style|key|ref|className|style|children)$/]",
        "message": "<StageItem> doesn't accept that prop. Declared props: state, title, detail, duration, last, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StageItem'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:pending|running|completed|warning|failed)$/]",
        "message": "<StageItem> state must be one of 'pending' | 'running' | 'completed' | 'warning' | 'failed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarQuestion'] > JSXAttribute > JSXIdentifier[name!=/^(?:index|question|followUps|reveals|style|key|ref|className|style|children)$/]",
        "message": "<StarQuestion> doesn't accept that prop. Declared props: index, question, followUps, reveals, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|dot|size|children|style|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: tone, variant, dot, size, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:confirmed|validate|gap|uncertain|info|neutral)$/]",
        "message": "<StatusBadge> tone must be one of 'confirmed' | 'validate' | 'gap' | 'uncertain' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|outline|solid)$/]",
        "message": "<StatusBadge> variant must be one of 'soft' | 'outline' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<StatusBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|primary|removable|onRemove|onClick|size|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, primary, removable, onRemove, onClick, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Textarea'] > JSXAttribute > JSXIdentifier[name!=/^(?:rows|invalid|showCount|key|ref|className|style|children)$/]",
        "message": "<Textarea> doesn't accept that prop. Declared props: rows, invalid, showCount."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
