# Server Port
PORT=8080

# Analysis mode: mock (default, the protected Tier 1 floor) or gemini (real LLM pipeline)
ANALYSIS_MODE=mock

# --- Backend selection (ADR-0011) ---
# Vertex AI backend (default for this project; the GCP Free Trial credit applies).
# Authenticate once with: gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# Gemini Developer API backend (used only when GOOGLE_GENAI_USE_VERTEXAI is unset/false).
# Get a key at https://aistudio.google.com/
GOOGLE_API_KEY=

# Default models (spec 006)
GEMINI_MODEL_FAST=gemini-3.5-flash
GEMINI_MODEL_STRONG=gemini-3.1-pro-preview

# GitHub-lite evidence ingestion (spec 007). Optional, but recommended to avoid
# unauthenticated API rate limits. Never commit a real token.
GITHUB_TOKEN=
